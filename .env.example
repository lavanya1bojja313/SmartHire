# ─────────────────────────────────────────────────────────────────────────────
# ScheduleAI — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
ENV=local   # local | production

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/interview_scheduler

# ── Redis (Celery broker) ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-me-with-a-long-random-string

# ── Email (choose ONE provider) ───────────────────────────────────────────────
# Option A: SendGrid  →  https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# Option B: AWS SES
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Agent's "From" address (must be verified with your email provider)
AGENT_EMAIL_ADDRESS=interviews@yourcompany.com

# ── Slack Alerts ──────────────────────────────────────────────────────────────
# Incoming Webhook URL → https://api.slack.com/apps → Incoming Webhooks
SLACK_ALERT_WEBHOOK_URL=

# ── LLM ──────────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

LLM_PRIMARY_MODEL=gpt-4o
LLM_FALLBACK_MODEL=claude-3-5-sonnet-20241022
AGENT_MAX_NEGOTIATION_LOOPS=3

# ── Google Calendar OAuth2 ────────────────────────────────────────────────────
# SETUP STEPS:
#   1. Go to https://console.cloud.google.com/
#   2. Create a Project → Enable "Google Calendar API"
#   3. Go to APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   4. Application type: "Web application"
#   5. Add Authorized redirect URI: http://localhost:8000/auth/google/callback
#   6. Copy your Client ID and Client Secret below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Token Encryption ─────────────────────────────────────────────────────────
# Generate a secure key with:  python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_ENCRYPTION_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
