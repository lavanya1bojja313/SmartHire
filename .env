# ── Gmail SMTP (easiest alternative to SendGrid) ─────────────────────────────
# Generate an App Password at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
GMAIL_USER=naveenkumarchowdary14113@gmail.com
GMAIL_APP_PASSWORD=apiaeyuiqcmrnfxn

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match what's registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Microsoft Graph OAuth ─────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# ── Slack (optional — for human escalation alerts) ────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ── Debug ─────────────────────────────────────────────────────────────────────
# Print SQL queries to stdout (true/false)
SQL_ECHO=false
# Log slow requests that exceed this threshold (seconds)
SLOW_REQUEST_THRESHOLD=1.0
