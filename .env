# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev uses the docker-compose postgres service (host = "db")
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/interview_scheduler

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=3c6be7df267c36aa9b59c0bd9e2e8ae4ef21c66247be46fa56470e7bcc62b83a5

# ── LLM ───────────────────────────────────────────────────────────────────────
